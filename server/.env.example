# Server env
# Copy to `server/.env` in development.

NODE_ENV=development
PORT=3001

# Required for /chat
# AI_PROVIDER: openai | gemini
# If AI_PROVIDER is unset and GEMINI_API_KEY exists, provider defaults to gemini.
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_DELAY_MS=250
OPENAI_CIRCUIT_FAILURE_THRESHOLD=4
OPENAI_CIRCUIT_RESET_MS=20000
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0

# Security
CORS_ALLOWLIST=http://localhost:8081,http://localhost:19006
REQUIRE_API_AUTH=false
API_AUTH_TOKEN=
# Comma-separated trusted source IPs for API_AUTH_TOKEN usage (server-to-server only).
# Example: 10.0.1.12,10.0.1.13,127.0.0.1
INTERNAL_API_IP_ALLOWLIST=127.0.0.1
# Admin panel auth via reverse proxy / SSO (recommended for therapy queue admin routes).
ADMIN_PROXY_AUTH_REQUIRED=false
ADMIN_PROXY_SHARED_SECRET=
ADMIN_PROXY_SECRET_HEADER=x-admin-proxy-secret
ADMIN_PROXY_USER_HEADER=x-auth-request-email
ADMIN_PROXY_GROUPS_HEADER=x-auth-request-groups
ADMIN_PROXY_ALLOWED_USERS=
ADMIN_PROXY_ALLOWED_GROUPS=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_B64=
CORE_BACKEND_URL=http://localhost:3000
CORE_BACKEND_TIMEOUT_MS=12000
CORE_HEALTH_TIMEOUT_MS=2500
CORE_HEALTH_CACHE_MS=30000
ENABLE_METRICS_ENDPOINT=true
METRICS_AUTH_TOKEN=
# Optional operational alerts webhook (Slack/PagerDuty bridge, etc.)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=
ALERT_TIMEOUT_MS=4000
ALERT_MIN_INTERVAL_MS=300000
# Accountability SMS (Twilio) - optional. If disabled/unset, app falls back to SMS composer.
ACCOUNTABILITY_SMS_ENABLED=false
ACCOUNTABILITY_SMS_TIMEOUT_MS=8000
ACCOUNTABILITY_SMS_COOLDOWN_MS=1200000
ACCOUNTABILITY_SMS_DAILY_LIMIT=8
ACCOUNTABILITY_SMS_IDEMPOTENCY_WINDOW_MS=600000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
# Set true (or proxy hop count like 1) behind reverse proxy/load balancer.
TRUST_PROXY=false

# Rate limit
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=25
PREMIUM_RATE_LIMIT_WINDOW_MS=60000
PREMIUM_RATE_LIMIT_MAX=20
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=60

# Premium
PREMIUM_DATA_FILE=./data/premium-state.json
DIARY_DATA_FILE=./data/diary-state.json
URGE_DATA_FILE=./data/urge-state.json
MONEY_PROTECTION_DATA_FILE=./data/money-protection-state.json
PREMIUM_DB_PATH=./data/premium-events.db
PREMIUM_CODE_ALLOWLIST=
# Keep false for IAP-only release. Set true only if you intentionally use activation codes.
ENABLE_PREMIUM_CODE_ACTIVATION=false
IAP_VALIDATOR_URL=
IAP_VALIDATOR_API_KEY=
IAP_IOS_SHARED_SECRET=
IAP_ANDROID_PACKAGE_NAME=
IAP_GOOGLE_SERVICE_ACCOUNT_JSON_B64=
IAP_STORE_TIMEOUT_MS=12000
IAP_PRODUCT_MONTHLY=antislot_premium_monthly
IAP_PRODUCT_YEARLY=antislot_premium_yearly
IAP_PRODUCT_LIFETIME=antislot_premium_lifetime
ALLOW_DEV_RECEIPT_BYPASS=true
IAP_WEBHOOK_SECRET=

# Production notes:
# - NODE_ENV=production
# - REQUIRE_API_AUTH=true and set either API_AUTH_TOKEN or FIREBASE_PROJECT_ID
# - If API_AUTH_TOKEN is used in production, INTERNAL_API_IP_ALLOWLIST is required
# - If ADMIN_PROXY_AUTH_REQUIRED=true, ADMIN_PROXY_SHARED_SECRET is required
# - IAP_WEBHOOK_SECRET is required
# - ALLOW_DEV_RECEIPT_BYPASS must be false
# - DATABASE_URL required in production (Postgres)
# - ALERT_WEBHOOK_URL recommended in production (critical alert delivery)
# - Apple: IAP_IOS_SHARED_SECRET from App Store Connect
# - Google: IAP_GOOGLE_SERVICE_ACCOUNT_JSON_B64 (base64), IAP_ANDROID_PACKAGE_NAME
