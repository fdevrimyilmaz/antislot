# Server (AI/Premium API) Production Environment
# Copy to .env.production; secrets from secret manager
# NEVER commit real secrets
# Strict preflight (go-live gate) requires:
# - OPENAI_API_KEY
# - CORS_ALLOWLIST
# - DATABASE_URL
# - IAP_WEBHOOK_SECRET
# - ALERT_WEBHOOK_URL (https://...)
# - one auth mode: API_AUTH_TOKEN or FIREBASE_PROJECT_ID
# - one IAP validation mode: IAP_VALIDATOR_URL or IAP_IOS_SHARED_SECRET or IAP_GOOGLE_SERVICE_ACCOUNT_JSON_B64

NODE_ENV=production
PORT=3001

# OpenAI (required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_DELAY_MS=250
OPENAI_CIRCUIT_FAILURE_THRESHOLD=4
OPENAI_CIRCUIT_RESET_MS=20000
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Security (required)
CORS_ALLOWLIST=https://app.antislot.app,https://antislot.app
REQUIRE_API_AUTH=true
API_AUTH_TOKEN=
# Admin panel auth via reverse proxy / SSO (recommended)
ADMIN_PROXY_AUTH_REQUIRED=true
ADMIN_PROXY_SHARED_SECRET=
ADMIN_PROXY_SECRET_HEADER=x-admin-proxy-secret
ADMIN_PROXY_USER_HEADER=x-auth-request-email
ADMIN_PROXY_GROUPS_HEADER=x-auth-request-groups
# Choose at least one allowlist strategy:
# - users only: ADMIN_PROXY_ALLOWED_USERS=ops@antislot.app
# - groups only: ADMIN_PROXY_ALLOWED_GROUPS=antislot-admins
ADMIN_PROXY_ALLOWED_USERS=ops@antislot.app
ADMIN_PROXY_ALLOWED_GROUPS=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_B64=
CORE_BACKEND_URL=
CORE_BACKEND_TIMEOUT_MS=12000
CORE_HEALTH_TIMEOUT_MS=2500
CORE_HEALTH_CACHE_MS=30000
ENABLE_METRICS_ENDPOINT=true
METRICS_AUTH_TOKEN=
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=
ALERT_TIMEOUT_MS=4000
ALERT_MIN_INTERVAL_MS=300000
# Accountability SMS (Twilio)
ACCOUNTABILITY_SMS_ENABLED=true
ACCOUNTABILITY_SMS_TIMEOUT_MS=8000
ACCOUNTABILITY_SMS_COOLDOWN_MS=1200000
ACCOUNTABILITY_SMS_DAILY_LIMIT=8
ACCOUNTABILITY_SMS_IDEMPOTENCY_WINDOW_MS=600000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
# true or hop count (recommended: 1 when behind single reverse proxy)
TRUST_PROXY=1

# Rate limits
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=25
PREMIUM_RATE_LIMIT_WINDOW_MS=60000
PREMIUM_RATE_LIMIT_MAX=20
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=60

# Premium storage (required in production)
DATABASE_URL=postgresql://antislot:PASSWORD@postgres:5432/antislot
# PREMIUM_DATA_FILE is ignored in production (kept for local/dev fallback only)
# DIARY_DATA_FILE is ignored in production (kept for local/dev fallback only)
# URGE_DATA_FILE is ignored in production (kept for local/dev fallback only)
# MONEY_PROTECTION_DATA_FILE is ignored in production (kept for local/dev fallback only)

PREMIUM_CODE_ALLOWLIST=
IAP_VALIDATOR_URL=
IAP_VALIDATOR_API_KEY=
IAP_IOS_SHARED_SECRET=
IAP_ANDROID_PACKAGE_NAME=
IAP_GOOGLE_SERVICE_ACCOUNT_JSON_B64=
IAP_STORE_TIMEOUT_MS=12000
IAP_PRODUCT_MONTHLY=antislot_premium_monthly
IAP_PRODUCT_YEARLY=antislot_premium_yearly
IAP_PRODUCT_LIFETIME=antislot_premium_lifetime
ALLOW_DEV_RECEIPT_BYPASS=false
IAP_WEBHOOK_SECRET=
