# Client env (Expo)
# Copy to `.env.local` for development.
# Do not commit `.env.local`.

# API
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WEBSITE_BASE_URL=https://antislot-legal.vercel.app

# Monitoring (all optional, opt-in controlled in-app)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENV=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.0
EXPO_PUBLIC_SENTRY_PROFILES_SAMPLE_RATE=0.0

# Feature flags (default: false; set to true only when store setup is complete)
EXPO_PUBLIC_ENABLE_SMS_ROLE=false
EXPO_PUBLIC_ENABLE_IAP=false
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=false
# Optional: keep false for IAP-only release; true enables access-code activation UI on Premium screen.
EXPO_PUBLIC_ENABLE_PREMIUM_CODE_ACTIVATION=false
# Premium free mode override (true = all premium features open for everyone)
EXPO_PUBLIC_PREMIUM_FREE_FOR_NOW=false

# Live support agent identity (used by direct support chat)
EXPO_PUBLIC_LIVE_SUPPORT_AGENT_ID=live_support_agent_1
EXPO_PUBLIC_LIVE_SUPPORT_AGENT_NAME_TR=Canli Destek Uzmani
EXPO_PUBLIC_LIVE_SUPPORT_AGENT_NAME_EN=Live Support Specialist

# Firebase (public client config)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
