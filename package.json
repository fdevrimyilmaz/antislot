{
  "name": "antislot",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/expo-start.js",
    "start:8082": "expo start --port 8082 --clear",
    "start:dev": "node ./scripts/expo-start.js --dev-client",
    "start:go": "node ./scripts/expo-start.js --go",
    "start:clear": "node ./scripts/expo-start.js --clear",
    "start:tunnel": "node ./scripts/expo-start.js --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "clean": "node ./scripts/clean-cache.js",
    "clean:all": "node ./scripts/clean-cache.js --all",
    "bump-version": "node ./scripts/bump-version.js",
    "check:conflicts": "node ./scripts/check-merge-conflicts.js",
    "i18n:report": "node ./scripts/i18n-coverage-report.js",
    "i18n:report:json": "node ./scripts/i18n-coverage-report.js --json",
    "i18n:report:strict": "node ./scripts/i18n-coverage-report.js --strict",
    "i18n:report:strict:json:file": "node ./scripts/i18n-coverage-report.js --strict --json --output reports/i18n-coverage.json",
    "quality": "npm run check:conflicts && npm run i18n:report:strict && npm run lint && npm run typecheck && npm run test -- --passWithNoTests && npm test --prefix backend && npm run build --prefix backend && npm test --prefix server && npm run build --prefix server",
    "preflight:release": "node ./scripts/release-preflight.js --target=full",
    "preflight:release:mobile": "node ./scripts/release-preflight.js --target=mobile",
    "preflight:release:backend": "node ./scripts/release-preflight.js --target=backend",
    "preflight:store": "node ./scripts/store-assets-check.js",
    "preflight:prod-final": "node ./scripts/prod-final-checks.js && npm run security:gate",
    "preflight:prod-final:strict-urls": "node ./scripts/prod-final-checks.js --enforce-public-urls && npm run security:gate",
    "security:gate": "node ./scripts/security-gate.js",
    "security:baseline:update": "node ./scripts/security-gate.js --update-baseline",
    "load:smoke:server": "npm run load:smoke --prefix server",
    "backup:drill:server": "npm run backup:drill --prefix server",
    "migrate:money-protection:tables:server": "npm run migrate:money-protection:tables --prefix server",
    "verify:money-protection:tables:server": "npm run verify:money-protection:tables --prefix server",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "node ./scripts/expo-start.js --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "e2e:maestro": "maestro test e2e/maestro",
    "e2e:maestro:diary": "maestro test e2e/maestro/diary-flow.yaml",
    "e2e:maestro:diary-stress": "maestro test e2e/maestro/diary-stress-flow.yaml",
    "e2e:maestro:mindfulness": "maestro test e2e/maestro/mindfulness-flow.yaml",
    "e2e:maestro:sms-filter": "maestro test e2e/maestro/sms-filter-flow.yaml",
    "e2e:maestro:money-protection": "maestro test e2e/maestro/money-protection-flow.yaml",
    "e2e:maestro:critical": "maestro test e2e/maestro/diary-flow.yaml && maestro test e2e/maestro/mindfulness-flow.yaml && maestro test e2e/maestro/sms-filter-flow.yaml && maestro test e2e/maestro/money-protection-flow.yaml",
    "e2e:detox:build:android": "detox build -c android.emu.debug",
    "e2e:detox:test:android": "detox test -c android.emu.debug",
    "e2e:detox:test:android:diary": "detox test -c android.emu.debug e2e/detox/diary.e2e.js",
    "e2e:detox:test:android:diary-stress": "detox test -c android.emu.debug e2e/detox/diary-stress.e2e.js",
    "e2e:detox:test:android:mindfulness": "detox test -c android.emu.debug e2e/detox/mindfulness.e2e.js",
    "e2e:detox:test:android:sms-filter": "detox test -c android.emu.debug e2e/detox/sms-filter.e2e.js",
    "e2e:detox:test:android:money-protection": "detox test -c android.emu.debug e2e/detox/money-protection.e2e.js",
    "e2e:detox:test:android:critical": "detox test -c android.emu.debug e2e/detox/diary.e2e.js e2e/detox/mindfulness.e2e.js e2e/detox/sms-filter.e2e.js e2e/detox/money-protection.e2e.js",
    "e2e:detox:build:ios": "detox build -c ios.sim.debug",
    "e2e:detox:test:ios": "detox test -c ios.sim.debug",
    "prepare": "husky install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.8.0",
    "i18n-js": "^4.5.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iap": "^14.7.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "detox": "^20.29.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-template-bare-minimum": "^54.0.48",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^15.3.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix --max-warnings=0 --cache"
  },
  "private": true
}
