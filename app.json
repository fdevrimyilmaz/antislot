{
  "expo": {
    "name": "Antislot",
    "slug": "antislot",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "antislot",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#1D4C72",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.antislot.app",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.antislot.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "ENABLE_IOS_NE": false,
        "NSUserTrackingUsageDescription": "Antislot kullanıcı izleme yapmaz. Bu izin yalnızca üçüncü taraf SDK'lar tarafından isteniyorsa görünür ve reddedilebilir.",
        "NSLocalNetworkUsageDescription": "Yerel ağda DNS düzeyinde kumar siteleri filtrelemesi için cihaz içi VPN bağlantısı kurulur. Veri uzaktaki bir sunucuya gönderilmez.",
        "NSAppleEventsUsageDescription": "Antislot Apple Events kullanmaz."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.antislot.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1D4C72",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-notifications",
      "react-native-iap",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5abd5fc8-dfbd-4672-a33e-74ea0bbb55fd"
      },
      "privacyPolicyUrl": "https://antislot-legal.vercel.app/privacy",
      "termsUrl": "https://antislot-legal.vercel.app/terms",
      "supportEmail": "support@antislot.app",
      "supportUrl": "https://antislot-legal.vercel.app/support"
    },
    "owner": "512ferhat512",
    "description": "Kumar dürtüleriyle başa çıkmak için destek araçları: kriz desteği, farkındalık ve ilerleme takibi, yapay zeka destekli sohbet ve cihazda güvenli veri saklama."
  }
}
