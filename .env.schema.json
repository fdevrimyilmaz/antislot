{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AntiSlot Environment Schema",
  "version": 1,
  "profiles": {
    "mobile.production": {
      "required": [
        "EXPO_PUBLIC_API_URL",
        "EXPO_PUBLIC_SENTRY_DSN"
      ],
      "booleans": {
        "EXPO_PUBLIC_PREMIUM_FREE_FOR_NOW": false,
        "EXPO_PUBLIC_ENABLE_PREMIUM_CODE_ACTIVATION": false
      },
      "notes": [
        "Inject EXPO_PUBLIC_* values through EAS environment variables and CI secrets.",
        "Do not inject private server secrets into EXPO_PUBLIC_*."
      ]
    },
    "server.production": {
      "required": [
        "CORS_ALLOWLIST",
        "CORE_BACKEND_URL",
        "DATABASE_URL",
        "IAP_WEBHOOK_SECRET",
        "SENTRY_DSN",
        "ALERT_WEBHOOK_URL",
        "ALERT_WEBHOOK_BEARER_TOKEN"
      ],
      "oneOf": [
        {
          "name": "auth_mode",
          "keys": [
            "API_AUTH_TOKEN",
            "FIREBASE_PROJECT_ID"
          ]
        },
        {
          "name": "iap_validation_mode",
          "keys": [
            "IAP_VALIDATOR_URL",
            "IAP_IOS_SHARED_SECRET",
            "IAP_GOOGLE_SERVICE_ACCOUNT_JSON_B64"
          ]
        },
        {
          "name": "ai_provider_mode",
          "keys": [
            "OPENAI_API_KEY",
            "GEMINI_API_KEY"
          ]
        }
      ]
    },
    "backend.production": {
      "required": [
        "HMAC_SECRET",
        "CORS_ALLOWLIST",
        "SENTRY_DSN"
      ],
      "oneOf": [
        {
          "name": "auth_mode",
          "keys": [
            "API_AUTH_TOKEN",
            "FIREBASE_PROJECT_ID"
          ]
        },
        {
          "name": "ai_provider_mode",
          "keys": [
            "OPENAI_API_KEY",
            "GEMINI_API_KEY"
          ]
        }
      ]
    }
  }
}
