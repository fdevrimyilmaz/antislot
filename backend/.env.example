PORT=3000
NODE_ENV=development

# Security
CORS_ALLOWLIST=http://localhost:8081,http://localhost:19006
REQUIRE_API_AUTH=false
API_AUTH_TOKEN=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_B64=
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# Telegram bot ingest (internal automation for new gambling domains)
TELEGRAM_INGEST_ENABLED=false
TELEGRAM_INGEST_TOKEN=
TELEGRAM_INGEST_MAX_DOMAINS=50
# Worker script vars (`npm run telegram:ingest`)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_INGEST_BASE_URL=http://localhost:3000
TELEGRAM_OFFSET_FILE=./data/telegram-offset.json
TELEGRAM_POLL_TIMEOUT_SEC=5
TELEGRAM_WORKER_MAX_BATCH=50
TELEGRAM_DRY_RUN=false
TELEGRAM_WORKER_CONTINUOUS=false
TELEGRAM_IDLE_DELAY_MS=2000
TELEGRAM_ERROR_BACKOFF_MS=10000
TELEGRAM_HTTP_TIMEOUT_MS=15000
TELEGRAM_FETCH_RETRIES=3
TELEGRAM_INGEST_RETRIES=2
TELEGRAM_RETRY_BASE_MS=1500

# Signing
HMAC_SECRET=antislot-secret-key-change-in-production

# AI provider
# AI_PROVIDER: openai | gemini
# If AI_PROVIDER is unset and GEMINI_API_KEY exists, provider defaults to gemini.
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_TOKENS=300

# Observability (optional)
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
