# Backend API
PORT=3000
NODE_ENV=development
HMAC_SECRET=change-me

# Storage
DATA_DIR=./data
BLOCKLIST_FILE=./data/blocklist.json
PATTERNS_FILE=./data/patterns.json
AUTO_VERSION_BUMP=true

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_TOKENS=300

# Premium access codes (comma-separated, uppercase). Leave empty to disable redemption.
PREMIUM_ACCESS_CODES=

# Telegram admin bot (server-managed blocklist)
# 1. Get token from @BotFather → TELEGRAM_BOT_TOKEN
# 2. Generate a random secret (openssl rand -hex 32) → TELEGRAM_WEBHOOK_SECRET
# 3. Register webhook: curl -X POST "https://api.telegram.org/bot$TOKEN/setWebhook" \
#      -d "url=https://YOUR_HOST/v1/telegram/webhook/$SECRET" \
#      -d "secret_token=$SECRET"
# 4. Message the bot once; copy your numeric chat ID into TELEGRAM_ADMIN_CHAT_IDS
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_IDS=
