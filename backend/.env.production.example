# Backend Production Environment
# Copy to .env.production and populate with secrets from secret manager
# NEVER commit real secrets to git
# Strict preflight (go-live gate) requires:
# - CORS_ALLOWLIST
# - one AI key: OPENAI_API_KEY or GEMINI_API_KEY
# - one auth mode: API_AUTH_TOKEN or FIREBASE_PROJECT_ID

NODE_ENV=production
PORT=3000

# Security (required)
HMAC_SECRET=             # From secret manager; non-empty in production
CORS_ALLOWLIST=          # Comma-separated: https://app.antislot.app,https://antislot.app
REQUIRE_API_AUTH=true
API_AUTH_TOKEN=          # Optional; if set, static token auth
FIREBASE_PROJECT_ID=     # For Firebase bearer validation
FIREBASE_SERVICE_ACCOUNT_JSON_B64=   # Base64-encoded service account JSON

# Data
DATA_DIR=/var/lib/antislot/data
BLOCKLIST_FILE=/var/lib/antislot/data/blocklist.json
PATTERNS_FILE=/var/lib/antislot/data/patterns.json
AUTO_VERSION_BUMP=true

# AI provider (for /v1/ai/chat)
AI_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_TOKENS=300

# Rate limit
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=60000

# Observability (recommended)
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
