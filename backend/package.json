{
  "name": "antislot-backend",
  "version": "1.0.0",
  "description": "Backend API for AntiSlot gambling blocker",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "watch": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "admin": "ts-node src/cli/admin.ts",
    "suggest": "ts-node src/scripts/suggest-domains.ts",
    "integrate-suggestions": "ts-node src/scripts/integrate-suggestions.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@sentry/node": "^10.39.0",
    "crypto": "^1.0.1",
    "fastify": "^5.7.4",
    "firebase-admin": "^12.7.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
